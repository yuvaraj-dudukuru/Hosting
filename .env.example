# ─────────────────────────────────────────────────────────────
# Fraylon Hosting — environment variables
# Copy this file to `.env` (never commit `.env`).
# ─────────────────────────────────────────────────────────────

# Razorpay credentials
# Get keys from: https://dashboard.razorpay.com/app/keys
# Use rzp_test_* for development, rzp_live_* for production.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace-with-your-secret

# Optional: configure a webhook secret if you set up Razorpay webhooks
# (Dashboard → Settings → Webhooks). Used to verify webhook authenticity.
RAZORPAY_WEBHOOK_SECRET=

# Server
PORT=4242
NODE_ENV=development
LOG_LEVEL=info

# CORS — comma-separated list of allowed origins.
# In dev, this should include your Vite dev server URL.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4242

# Frontend base URL — used when generating absolute redirect / receipt URLs.
PUBLIC_BASE_URL=http://localhost:5173

# Currency for orders. Razorpay accepts INR, USD, etc.
DEFAULT_CURRENCY=INR

# GST percent applied at checkout (server-side authority)
GST_PERCENT=18
